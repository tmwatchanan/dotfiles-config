{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow"
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "context-mode@latest",
    "@tarquinen/opencode-dcp@latest",
    "@slkiser/opencode-quota@latest",
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "percentDisplayMode": "used",
      "formatStyle": "allWindows",
      "opencodeGoWindows": [
        "rolling",
        "weekly",
        "monthly"
      ]
    }
  },
  "lsp": true
}
