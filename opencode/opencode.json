{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow"
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    }
  },
  "plugin": [
    "context-mode@latest",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim@latest",
    "@slkiser/opencode-quota@latest"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "classic",
      "percentDisplayMode": "used"
    }
  }
}
