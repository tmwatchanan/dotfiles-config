{
  // Weave config for OpenCode Go subscription.
  // Maps agents away from default Claude models onto opencode-go/* tiers.
  // Tiering follows the "7-model OpenCode Go benchmark" Reddit post:
  //   1. deepseek-v4-flash — default for high-volume agent loops (1M ctx, cheap, fast)
  //   2. deepseek-v4-pro   — best for fewer, harder one-shot reasoning calls
  //   3. qwen3.6-plus      — long context + commercial tooling
  //   4. kimi-k2.6         — strong multimodal/agent fallback
  //   5. glm-5.1           — coding-heavy fallback (200K ctx limits orchestration)
  //   6. minimax-m2.7      — cheap practical fallback
  // Free-tier fallback (opencode/*):
  //   - nemotron-3-super-free — strong reasoning, used for spindle external research
  "$schema": "https://raw.githubusercontent.com/pgermishuys/opencode-weave/v0.7.6/schema/weave-config.schema.json",

  "agents": {
    // Orchestrator — fewer, harder strategic calls → Pro
    "loom": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/qwen3.6-plus",
        "opencode-go/kimi-k2.6"
      ]
    },
    // Execution orchestrator — long loop driver → Flash (cheap, 1M ctx)
    "tapestry": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5.1"
      ]
    },
    // Category worker — high-volume loop work → Flash
    "shuttle": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "opencode-go/minimax-m2.7"
      ]
    },
    // Strategic planner — top reasoning → Pro
    "pattern": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-flash"
      ]
    },
    // Codebase explorer — fast/cheap, large ctx for crawling
    "thread": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/mimo-v2-omni"
      ]
    },
    // External researcher — fast/cheap, free tier OK
    "spindle": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode/nemotron-3-super-free"
      ]
    },
    // Reviewer/auditor — strong reasoning per call → Pro
    "weft": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "opencode-go/kimi-k2.6",
        "opencode-go/glm-5.1"
      ]
    },
    // Security auditor — heaviest skeptical reasoning → Pro
    "warp": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5.1"
      ]
    }
  }
}
