{
  // Weave config for OpenCode Go subscription.
  // Maps agents away from default Claude models onto opencode-go/* tiers.
  //
  // Mapping mirrors the oh-my-opencode-slim "opencode-go" preset
  // (https://github.com/alvinunreal/oh-my-opencode-slim/blob/38e6f7d/docs/opencode-go-preset.md):
  //   slim Orchestrator -> loom         (glm-5.1)
  //   slim Oracle       -> pattern, warp (deepseek-v4-pro, heaviest reasoning)
  //   slim Council      -> weft         (deepseek-v4-pro, review)
  //   slim Fixer        -> tapestry, shuttle (deepseek-v4-flash, loop workers)
  //   slim Explorer     -> thread       (minimax-m2.7, codebase nav)
  //   slim Librarian    -> spindle      (minimax-m2.7, external docs/research)
  //
  // Tier rationale:
  //   - deepseek-v4-pro   : deepest single-shot reasoning (Oracle/Council slot)
  //   - deepseek-v4-flash : cheap, fast, 1M ctx — loop drivers
  //   - glm-5.1           : capable orchestrator/coordinator
  //   - kimi-k2.6         : strong reasoning fallback, multimodal-friendly
  //   - qwen3.6-plus      : long context + commercial tooling fallback
  //   - minimax-m2.7      : retrieval/exploration tier
  //   - mimo-v2.5         : cheap practical fallback
  // Free-tier fallback (opencode/*):
  //   - nemotron-3-super-free — strong reasoning, used for spindle external research
  "$schema": "https://raw.githubusercontent.com/pgermishuys/opencode-weave/v0.7.6/schema/weave-config.schema.json",

  "agents": {
    // Orchestrator — top-level dispatcher (slim Orchestrator)
    "loom": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus"
      ]
    },
    // Execution orchestrator — long loop driver (slim Fixer)
    "tapestry": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/glm-5.1",
        "opencode-go/qwen3.6-plus",
        "opencode-go/minimax-m2.7"
      ]
    },
    // Category worker — high-volume loop work (slim Fixer)
    "shuttle": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "opencode-go/minimax-m2.7",
        "opencode-go/mimo-v2.5"
      ]
    },
    // Strategic planner — top reasoning (slim Oracle)
    "pattern": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5.1"
      ]
    },
    // Codebase explorer — retrieval-tier (slim Explorer)
    "thread": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/qwen3.6-plus",
        "opencode-go/mimo-v2.5"
      ]
    },
    // External researcher — docs/knowledge (slim Librarian)
    "spindle": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "opencode-go/deepseek-v4-flash",
        "opencode/nemotron-3-super-free"
      ]
    },
    // Reviewer/auditor — strong reasoning per call (slim Council)
    "weft": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5.1"
      ]
    },
    // Security auditor — heaviest skeptical reasoning (slim Oracle)
    "warp": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5.1"
      ]
    }
  }
}
