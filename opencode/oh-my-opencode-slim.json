{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "preset": "my-mix",
  "presets": {
    "my-mix": {
      "orchestrator": {
        "model": "opencode-go/kimi-k2.6",
        "variant": "high",
        "skills": ["*"],
        "mcps": ["*"]
      },
      "oracle": {
        "model": "opencode-go/kimi-k2.6",
        "variant": "high",
        "skills": ["simplify"],
        "mcps": []
      },
      "librarian": {
        "model": "opencode-go/minimax-m2.7",
        "variant": "low",
        "skills": [],
        "mcps": ["websearch", "context7", "grep_app"]
      },
      "explorer": {
        "model": "opencode-go/minimax-m2.7",
        "variant": "low",
        "skills": [],
        "mcps": []
      },
      "designer": {
        "model": "opencode-go/mimo-v2-omni",
        "skills": ["agent-browser"],
        "mcps": []
      },
      "fixer": {
        "model": "opencode-go/glm-5.1",
        "variant": "low",
        "skills": [],
        "mcps": []
      }
    }
  },
  "multiplexer": {
    "type": "auto",
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "council": {
    "master": { "model": "opencode-go/kimi-k2.6", "variant": "high" },
    "presets": {
      "default": {
        "alpha": { "model": "opencode-go/glm-5.1", "variant": "high" },
        "beta":  { "model": "opencode-go/qwen3.6-plus" },
        "gamma": { "model": "opencode-go/minimax-m2.7", "variant": "high" }
      }
    }
  },
  "fallback": {
    "enabled": true,
    "timeoutMs": 20000,
    "retryDelayMs": 500,
    "chains": {
      "orchestrator": ["opencode-go/kimi-k2.5", "opencode-go/glm-5.1"],
      "oracle": ["opencode-go/glm-5.1", "opencode-go/kimi-k2.5"],
      "designer": ["opencode-go/mimo-v2-pro", "opencode-go/kimi-k2.5"],
      "fixer": ["opencode-go/kimi-k2.5", "opencode-go/minimax-m2.7"],
      "librarian": ["opencode-go/minimax-m2.5", "opencode-go/qwen3.6-plus"],
      "explorer": ["opencode-go/minimax-m2.5", "opencode-go/kimi-k2.5"],
      "council-master": ["opencode-go/glm-5.1", "opencode-go/qwen3.6-plus"],
      "councillor": ["opencode-go/kimi-k2.5", "opencode-go/minimax-m2.7"]
    }
  }
}
